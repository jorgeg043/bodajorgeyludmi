---
import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import Contador from '../components/contador.astro';
---

<Layout title="L & J | 2027">
    <Intro />
    
    <main class="h-screen w-full overflow-y-auto snap-y snap-mandatory scroll-smooth touch-pan-y antialiased">
        
        <section class="snap-start relative w-full h-[100dvh] overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 z-0">
                <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/70 z-10"></div>
                <img 
                    src="/images/hero.jpg" 
                    class="w-full h-full object-cover object-center scale-105 animate-slow-zoom"
                    alt="Boda Ludmila y Jorge"
                />
            </div>

            <div class="relative z-20 flex flex-col items-center text-center px-6">
                <span class="text-amber-200 text-[10px] md:text-sm font-bold tracking-[0.5em] uppercase mb-6 opacity-0 animate-fade-in-up">
                    ¡ Nos casamos !
                </span>

                <h1 class="font-cookie text-7xl md:text-[10rem] text-white leading-none drop-shadow-2xl opacity-0 animate-fade-in-up-delayed">
                    Ludmila <span class="block md:inline">&</span> Jorge
                </h1>

                <div class="mt-12 flex flex-col items-center opacity-0 animate-fade-in-up-late">
                    <div class="w-12 h-[1px] bg-amber-200/50 mb-6"></div>
                    <p class="text-white/80 tracking-[0.6em] text-[9px] md:text-xs uppercase">
                        Punta Cana • 09.03.2027
                    </p>
                </div>
            </div>

            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 opacity-0 animate-fade-in-up-late">
                <div class="flex flex-col items-center gap-2">
                    <span class="text-[8px] uppercase tracking-widest text-white/30 font-bold">Scroll</span>
                    <div class="w-[1px] h-8 bg-gradient-to-b from-white/40 to-transparent"></div>
                </div>
            </div>
        </section>

        <section class="snap-start relative w-full h-screen overflow-hidden flex flex-col items-center justify-center p-4">
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px] z-10"></div>
        <img 
            src="/images/fondo-contador.jpg" 
            class="w-full h-full object-cover" 
            alt="Fondo Contador"
        />
    </div>

    <div class="relative z-20 w-full max-w-4xl flex flex-col items-center">
        <h2 class="text-amber-200 text-5xl md:text-7xl font-cookie mb-12 drop-shadow-lg opacity-0 animate-fade">
            Cuenta regresiva...
        </h2>
        
        <div class="w-full">
            <Contador />
        </div>
    </div>
</section>
        </section>

       <section class="snap-start relative w-full min-h-screen bg-[#050505] flex items-center justify-center py-20 px-4 overflow-hidden">
    
    <div class="max-w-6xl w-full relative z-10">
        
        <h2 class="text-center text-amber-200 text-5xl md:text-7xl font-cookie mb-24 opacity-0 animate-fade">
            Nuestra Historia
        </h2>

        <div class="flex flex-col md:flex-row items-center justify-around gap-16 md:gap-8">
            
            <div class="flex flex-col items-center group">
                <div class="relative p-1">
                    <div class="absolute -inset-2 bg-amber-400/30 rounded-[2.5rem] blur-2xl animate-pulse-glow"></div>
                    
                    <div class="absolute inset-0 border-2 border-amber-300 rounded-[2.2rem] shadow-[0_0_20px_rgba(251,191,36,0.8),inset_0_0_10px_rgba(251,191,36,0.4)] z-10 animate-pulse"></div>
                    
                    <div class="relative w-64 h-80 md:w-72 md:h-96 rounded-[2rem] overflow-hidden z-20">
                        <img src="/images/ludmila.jpg" class="w-full h-full object-cover" alt="Ludmila" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
                    </div>
                </div>
                <div class="mt-8 text-center max-w-xs">
                    <h3 class="font-cookie text-amber-200 text-5xl mb-3">Ludmila</h3>
                    <p class="text-slate-300 font-light italic text-sm md:text-base leading-relaxed">
                        "Encontré en vos todo lo que no sabía que necesitaba. Sos mi lugar favorito en el mundo."
                    </p>
                </div>
            </div>

            <div class="flex flex-col items-center py-12 md:py-0">
    <div class="relative group">
        <div class="absolute inset-0 bg-amber-500/40 blur-3xl rounded-full animate-pulse"></div>
        
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-20 h-20 fill-amber-400 relative z-10 drop-shadow-[0_0_25px_rgba(251,191,36,0.9)] transition-transform duration-700 group-hover:scale-110 animate-pulse">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            
            <path 
                fill="#050505" 
                d="M17.5 13.5v-1.5l-5-3.5v-3c0-.55-.45-1-1-1s-1 .45-1 1v3l-5 3.5v1.5l5-1.5v4l-1.5 1v1l2.5-.5 2.5.5v-1l-1.5-1v-4l5 1.5z"
                class="origin-center rotate-[45deg]"
            />
        </svg>
    </div>
    <p class="font-cookie text-amber-200/60 text-2xl mt-4 tracking-wider">Sí para siempre</p>
</div>

            <div class="flex flex-col items-center group">
                <div class="relative p-1">
                    <div class="absolute -inset-2 bg-amber-400/30 rounded-[2.5rem] blur-2xl animate-pulse-glow-delay"></div>
                    
                    <div class="absolute inset-0 border-2 border-amber-300 rounded-[2.2rem] shadow-[0_0_20px_rgba(251,191,36,0.8),inset_0_0_10px_rgba(251,191,36,0.4)] z-10 animate-pulse"></div>
                    
                    <div class="relative w-64 h-80 md:w-72 md:h-96 rounded-[2rem] overflow-hidden z-20">
                        <img src="/images/jorge.jpg" class="w-full h-full object-cover" alt="Jorge" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-transparent"></div>
                    </div>
                </div>
                <div class="mt-8 text-center max-w-xs">
                    <h3 class="font-cookie text-amber-200 text-5xl mb-3">Jorge</h3>
                    <p class="text-slate-300 font-light italic text-sm md:text-base leading-relaxed">
                        "Desde el primer día supe que serías mi compañera de aventuras. Gracias por caminar a mi lado."
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    /* Animación del aura de resplandor */
    @keyframes pulseGlow {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.1); }
    }

    .animate-pulse-glow {
        animation: pulseGlow 4s infinite ease-in-out;
    }

    .animate-pulse-glow-delay {
        animation: pulseGlow 4s infinite ease-in-out 2s;
    }
</style>

    </main>
</Layout>

<style>
    .animate-slow-zoom {
        animation: slowZoom 10s infinite alternate ease-in-out; /* Más lento para que no maree */
    }

    /* Ajustamos el delay para esperar a que el pasaporte se abra (aprox 1s) */
    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out 1.2s forwards;
    }

    .animate-fade-in-up-delayed {
        animation: fadeInUp 0.8s ease-out 1.5s forwards;
    }

    .animate-fade-in-up-late {
        animation: fadeInUp 0.8s ease-out 1.8s forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slowZoom {
        from { transform: scale(1.05); }
        to { transform: scale(1.15); }
    }
</style>

<style is:global>
    /* Estabilización de Scroll */
    main::-webkit-scrollbar { display: none; }
    main { -ms-overflow-style: none; scrollbar-width: none; }
    
    /* Animación genérica para secciones de abajo */
    .animate-fade {
        animation: fadeIn 1.5s ease-out forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>