<section class="snap-start relative w-full min-h-screen flex items-center justify-center overflow-hidden py-20 px-4">
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-black/50 z-10"></div> <img 
            src="/images/fondo-republica.jpg" 
            class="w-full h-full object-cover blur-sm scale-110" 
            alt="Fondo Punta Cana"
        />
    </div>

    <div class="relative z-20 max-w-4xl w-full text-center">
        <div class="mb-12 opacity-0 animate-fade">
            <h2 class="text-amber-200 text-5xl md:text-7xl font-cookie mb-6">El lugar de nuestra Boda</h2>
            <p class="text-white text-lg md:text-xl font-light leading-relaxed max-w-2xl mx-auto">
                Nuestro gran día empieza con un despegue. Salimos de casa con la valija llena de sueños para encontrarnos en las playas de República Dominicana. 
                <span class="block mt-4 text-amber-100/80 italic">Agenden la fecha, preparen el pasaporte y encontrémonos allá para disfrutar juntos.</span>
            </p>
        </div>

        <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-[2.5rem] p-8 md:p-12 shadow-2xl transition-transform hover:scale-[1.02] duration-500">
            
            <div class="mb-6 flex justify-center">
                <img 
                    src="/images/logo-hotel.png" 
                    class="h-20 md:h-28 object-contain" 
                    alt="Logo Grand Palladium"
                />
            </div>

            <div class="text-white">
                <span class="text-amber-200 uppercase tracking-[0.3em] text-xs font-bold">Alojamiento All Inclusive</span>
                <h3 class="text-3xl md:text-4xl font-serif mt-2 mb-1">Grand Palladium Punta Cana</h3>
                <p class="text-white/60 tracking-widest uppercase text-sm">Resort & Spa</p>
            </div>

            <div class="mt-10 flex flex-col items-center">
                <div class="mb-3 animate-bounce">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-amber-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                    <span class="text-amber-200 text-[10px] uppercase tracking-tighter font-bold">Haga click para reservar</span>
                </div>

                <a 
                    href="https://www.palladiumhotelgroup.com/es/bodas/ludmila-y-jorge" 
                    target="_blank" 
                    class="px-10 py-4 bg-amber-200 text-black font-bold rounded-full uppercase tracking-widest text-sm hover:bg-white transition-colors duration-300 shadow-[0_10px_20px_rgba(251,191,36,0.3)]"
                >
                    Reservar Ahora
                </a>
            </div>
        </div>
    </div>
</section>

<section class="snap-start relative w-full h-screen overflow-hidden flex items-center justify-center">
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-black/40 z-10"></div>
        
        <video 
            autoplay 
            muted 
            loop 
            playsinline 
            class="w-full h-full object-cover"
        >
            <source src="/videos/playa-fondo.mp4" type="video/mp4" />
            Tu navegador no soporta videos.
        </video>
    </div>

    <div class="relative z-20 px-6 max-w-5xl text-center">
        <h2 class="font-cookie text-5xl md:text-8xl text-white drop-shadow-[0_0_30px_rgba(255,255,255,0.5)] opacity-0 animate-fade-in-up">
            El mejor regalo de tu parte, <br class="hidden md:block" />
            será tu presencia en nuestra boda
        </h2>
        
        <div class="mt-8 flex justify-center opacity-0 animate-fade-in-up-delayed">
            <div class="h-[1px] w-24 bg-gradient-to-r from-transparent via-amber-200 to-transparent"></div>
            <div class="mx-4 text-amber-200 text-xl">✨</div>
            <div class="h-[1px] w-24 bg-gradient-to-r from-transparent via-amber-200 to-transparent"></div>
        </div>
    </div>
</section>





<style>
    /* Animación del aura de resplandor */
    @keyframes pulseGlow {
        0%, 100% { opacity: 0.3; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.1); }
    }

    .animate-pulse-glow {
        animation: pulseGlow 4s infinite ease-in-out;
    }

    .animate-pulse-glow-delay {
        animation: pulseGlow 4s infinite ease-in-out 2s;
    }
</style>

    </main>
</Layout>

<style>
    .animate-slow-zoom {
        animation: slowZoom 10s infinite alternate ease-in-out; /* Más lento para que no maree */
    }

    /* Ajustamos el delay para esperar a que el pasaporte se abra (aprox 1s) */
    .animate-fade-in-up {
        animation: fadeInUp 0.8s ease-out 1.2s forwards;
    }

    .animate-fade-in-up-delayed {
        animation: fadeInUp 0.8s ease-out 1.5s forwards;
    }

    .animate-fade-in-up-late {
        animation: fadeInUp 0.8s ease-out 1.8s forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slowZoom {
        from { transform: scale(1.05); }
        to { transform: scale(1.15); }
    }
</style>

<style is:global>
    /* Estabilización de Scroll */
    main::-webkit-scrollbar { display: none; }
    main { -ms-overflow-style: none; scrollbar-width: none; }
    
    /* Animación genérica para secciones de abajo */
    .animate-fade {
        animation: fadeIn 1.5s ease-out forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>