---
import Layout from '../layouts/Layout.astro';
import Intro from '../components/Intro.astro';
import Contador from '../components/contador.astro';
import MusicaFondo from '../components/MusicaFondo.astro'; // <--- IMPORTAR
---

<Layout title="L & J | 2027">
    <MusicaFondo /> <Intro />
    
    <main class="h-screen w-full overflow-y-auto snap-y snap-mandatory scroll-smooth touch-pan-y antialiased">
        
        <section class="snap-start relative w-full h-[100dvh] overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 z-0">
                <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-transparent to-black/70 z-10"></div>
                <img 
                    src="/images/hero.jpg" 
                    class="w-full h-full object-cover object-center scale-105 animate-slow-zoom"
                    alt="Boda Ludmila y Jorge"
                />
            </div>

            <div class="relative z-20 flex flex-col items-center text-center px-6">
                <span class="text-amber-200 text-[10px] md:text-sm font-bold tracking-[0.5em] uppercase mb-6 opacity-0 animate-fade-in-up">
                    ¡ Nos casamos !
                </span>

                <h1 class="font-cookie text-7xl md:text-[10rem] text-white leading-none drop-shadow-2xl opacity-0 animate-fade-in-up-delayed">
                    Ludmila <span class="block md:inline">&</span> Jorge
                </h1>

                <div class="mt-12 flex flex-col items-center opacity-0 animate-fade-in-up-late">
                    <div class="w-12 h-[1px] bg-amber-200/50 mb-6"></div>
                    <p class="text-white/80 tracking-[0.6em] text-[9px] md:text-xs uppercase">
                        Punta Cana • 09.03.2027
                    </p>
                </div>
            </div>

            <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 opacity-0 animate-fade-in-up-late">
                <div class="flex flex-col items-center gap-2">
                    <span class="text-[8px] uppercase tracking-widest text-white/30 font-bold">Scroll</span>
                    <div class="w-[1px] h-8 bg-gradient-to-b from-white/40 to-transparent"></div>
                </div>
            </div>
        </section>

        <section class="snap-start relative w-full h-screen overflow-hidden flex flex-col items-center justify-center p-4">
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px] z-10"></div>
        <img 
            src="/images/fondo-contador.jpg" 
            class="w-full h-full object-cover" 
            alt="Fondo Contador"
        />
    </div>

    <div class="relative z-20 w-full max-w-4xl flex flex-col items-center">
        <h2 class="text-amber-200 text-5xl md:text-7xl font-cookie mb-12 drop-shadow-lg opacity-0 animate-fade">
            Cuenta regresiva...
        </h2>
        
        <div class="w-full">
            <Contador />
        </div>
    </div>
</section>
        </section>

       <section class="snap-start relative w-full min-h-screen bg-[#050505] flex items-center justify-center py-20 px-4 overflow-hidden">
    <div class="max-w-6xl w-full relative z-10">
