   <div id="intro-content" class="absolute inset-0 flex flex-col items-center justify-end pb-20 md:pb-32 z-[120] transition-all duration-700">
    <button id="btn-ingresar" class="group relative px-12 py-5 bg-amber-400 text-[#001a33] font-black uppercase text-sm tracking-[0.3em] rounded-full shadow-[0_0_40px_rgba(0,0,0,0.5)] hover:scale-105 hover:bg-white transition-all active:scale-95 overflow-hidden">
        <span class="relative z-10 flex items-center gap-3">
            Ingresar ✈
        </span>
    </button>
</div>

<style>
    /* Efecto de apertura de telón suave */
    .open-left { 
        transform: translateX(-100%); 
    }
    .open-right { 
        transform: translateX(100%); 
    }
    
    .fade-out-content { 
        opacity: 0; 
        transform: scale(0.9);
        pointer-events: none; 
    }

    /* Curva de animación personalizada para que sea más natural */
    .cubic-bezier {
        transition-timing-function: cubic-bezier(0.7, 0, 0.3, 1);
    }
</style>

<script>
    const btn = document.getElementById('btn-ingresar');
    const overlay = document.getElementById('intro-overlay');
    const left = document.getElementById('door-left');
    const right = document.getElementById('door-right');
    const content = document.getElementById('intro-content');

    btn?.addEventListener('click', () => {
        // 1. Desvanecemos el botón inmediatamente
        content?.classList.add('fade-out-content');
        
        // 2. Abrimos las puertas (el fondo de la web ya se verá en las rendijas)
        left?.classList.add('open-left');
        right?.classList.add('open-right');

        // 3. Eliminamos el overlay del todo cuando termine de abrirse
        setTimeout(() => {
            overlay?.classList.add('hidden');
        }, 2100);
    });
</script>